<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
    <version>7.4</version>
    <template_groups>
        <template_group>
            <uuid>7df96b18c230490a9a0a9e2307226338</uuid>
            <name>Templates</name>
        </template_group>
    </template_groups>
    <templates>
        <template>
            <uuid>7c8b5d68f537457e8b3550b8c84ffa07</uuid>
            <template>dBmMonitoring</template>
            <name>dBmMonitoring</name>
            <groups>
                <group>
                    <name>Templates</name>
                </group>
            </groups>
            <discovery_rules>
                <discovery_rule>
                    <uuid>a7151682b0bb45efa50fd5b315797977</uuid>
                    <name>Interface Discovery</name>
                    <type>SNMP_AGENT</type>
                    <snmp_oid>discovery[{#IFNAME}, 1.3.6.1.2.1.2.2.1.2, {#IFTYPE}, 1.3.6.1.2.1.2.2.1.3]</snmp_oid>
                    <key>discovery.interfaces</key>
                    <delay>1h</delay>
                    <filter>
                        <evaltype>OR</evaltype>
                        <conditions>
                            <condition>
                                <macro>{#IFTYPE}</macro>
                                <value>6</value>
                            </condition>
                            <condition>
                                <macro>{#IFTYPE}</macro>
                                <value>135</value>
                            </condition>
                        </conditions>
                    </filter>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>f58eaf94ee7f4d0992e59576c8084f53</uuid>
                            <name>Interface {#IFNAME}: Rx Power</name>
                            <type>SNMP_AGENT</type>
                            <snmp_oid>get[1.3.6.1.4.1.14988.1.1.19.1.1.10.{#SNMPINDEX}]</snmp_oid>
                            <key>sfp.rx.power[{#SNMPINDEX}]</key>
                            <delay>10s</delay>
                            <value_type>FLOAT</value_type>
                            <units>dBm</units>
                            <preprocessing>
                                <step>
                                    <type>MULTIPLIER</type>
                                    <parameters>
                                        <parameter>0.001</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <tags>
                                <tag>
                                    <tag>hide</tag>
                                    <value>true</value>
                                </tag>
                            </tags>
                            <trigger_prototypes>
                                <trigger_prototype>
                                    <uuid>a0fe6d0d9358406082c19fa1e25bdafd</uuid>
                                    <expression>avg(/dBmMonitoring/sfp.rx.power[{#SNMPINDEX}],5m)&lt;-25</expression>
                                    <name>Rx Power too low (&lt; -25 dBm) on {#IFNAME}</name>
                                    <priority>HIGH</priority>
                                </trigger_prototype>
                                <trigger_prototype>
                                    <uuid>25b6b9f58e924737991a86c84f494862</uuid>
                                    <expression>avg(/dBmMonitoring/sfp.rx.power[{#SNMPINDEX}],5m)&lt;-40</expression>
                                    <name>Rx Power too low (&lt; -40 dBm) on {#IFNAME}</name>
                                    <priority>DISASTER</priority>
                                </trigger_prototype>
                            </trigger_prototypes>
                        </item_prototype>
                        <item_prototype>
                            <uuid>551b44a449064a268c6b9ebd70f48837</uuid>
                            <name>Interface {#IFNAME}: Tx Power</name>
                            <type>SNMP_AGENT</type>
                            <snmp_oid>get[1.3.6.1.4.1.14988.1.1.19.1.1.9.{#SNMPINDEX}]</snmp_oid>
                            <key>sfp.tx.power[{#SNMPINDEX}]</key>
                            <delay>10s</delay>
                            <value_type>FLOAT</value_type>
                            <units>dBm</units>
                            <preprocessing>
                                <step>
                                    <type>MULTIPLIER</type>
                                    <parameters>
                                        <parameter>0.001</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <tags>
                                <tag>
                                    <tag>hide</tag>
                                    <value>true</value>
                                </tag>
                            </tags>
                        </item_prototype>
                    </item_prototypes>
                </discovery_rule>
            </discovery_rules>
        </template>
    </templates>
</zabbix_export>
